# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_farm_dev
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=smart_farm_dev
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Server Configuration
PORT=3000
NODE_ENV=development

# API Security
API_KEY_REQUIRED=false
API_KEY=your_api_key_here

# Logging
LOG_LEVEL=info

# Features
ENABLE_VALIDATION_LOG=true
CONNECTION_POOL_SIZE=20

# MQTT Broker (for remote IoT Panel)
# Example (HiveMQ Cloud): mqtts://<cluster-host>:8883
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
